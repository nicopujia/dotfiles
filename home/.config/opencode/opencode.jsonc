{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "commit": {
      "description": "Commit and push frequently",
      "template": "Once you're sure things work, frequently make atomic commits and push. Do it now and throughout the rest of this session.",
    },
    "god": {
      "description": "Indicate the available power and its expectations.",
      "template": "You have full root access on this machine, so you have the same power as a human dev. You can install anything you need, test things however it's needed to ensure they actually work, etc. Thus, I expect you to have the same quality of results as a human senior engineer would. Start by onboarding yourself in the current repo investigating it using 10 parallel subagents. You will then receive several tasks to solve, but don't solve them yourself; be an orchestrator -- ALWAYS spawn a subagent for each of those tasks. Be ready to receive more tasks as the subagents work. Besides, those subagents should also spawn their own subagents for each task phase (reserach, planning, implementation, testing). Last but not least, commit frequently and push after you ensure things work. Ask any needed clarifying questions before starting a task.",
    },
    "onboard": {
      "description": "Onboard into repo using subagents.",
      "template": "Onboard yourself in the current repo investigating it using 10 parallel subagents.",
      "subtask": true,
    },
  },
  // Keep Python formatter/LSP hooks out of the global opencode config.
  // A global plugin handles lightweight post-edit Ruff formatting instead.
  "lsp": {
    "pyright": {
      "disabled": true,
    },
  },
  "mcp": {
    "grep-mcp": {
      "type": "local",
      "command": ["uvx", "grep-mcp"],
      "enabled": false,
    },
    "linear-mcp": {
      "type": "local",
      "command": ["bunx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
    },
  },
}
