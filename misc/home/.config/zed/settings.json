// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "terminal": {},
  "$schema": "zed://schemas/settings",
  "disable_ai": true,
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Monokai Night"
  },
  "minimap": {
    "show": "never"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false
  },
  "ssh_connections": [
    {
      "host": "66.179.138.29",
      "username": "nico",
      "args": [],
      "projects": [
        {
          "paths": ["/"]
        },
        {
          "paths": ["/home/nico"]
        },
        {
          "paths": ["/home/nico/justralph.it"]
        }
      ],
      "nickname": "pujia"
    },
    {
      "host": "pujia",
      "args": [],
      "projects": []
    }
  ],
  "vim_mode": true,
  "show_edit_predictions": false,
  "linked_edits": false,
  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "completions": {
    "words_min_length": 0
  },
  "edit_predictions": {
    "mode": "subtle"
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access"
      },
      "type": "registry"
    },
    "opencode": {
      "type": "extension",
      "favorite_models": [
        "anthropic/claude-haiku-4-5",
        "anthropic/claude-sonnet-4-5",
        "anthropic/claude-opus-4-6"
      ],
      "default_config_options": {
        "model": "openai/gpt-5.4/medium"
      },
      "favorite_config_option_values": {
        "model": ["openai/gpt-5.4", "openai/gpt-5.4/medium"]
      }
    }
  },
  "file_types": {
    "svg": ["html"]
  },
  "languages": {
    "XML": {
      "formatter": "language_server"
    },
    "HTML": {
      "tab_size": 2
    },
    "CSS": {
      "tab_size": 2
    },
    "JavaScript": {
      "tab_size": 2
    },
    "TypeScript": {
      "tab_size": 2,
      "preferred_line_length": 120
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-lc",
            "set -e; if [ -z \"$1\" ]; then printf '%s\\n' 'zed python formatter: missing buffer path' >&2; exit 1; fi; file_path=\"$1\"; tmp_dir=$(mktemp -d); input_file=\"$tmp_dir/input.py\"; checked_file=\"$tmp_dir/checked.py\"; cleanup() { rm -rf \"$tmp_dir\"; }; trap cleanup EXIT HUP INT TERM; cat > \"$input_file\"; uv run --no-project ruff check --exit-zero --fix --stdin-filename \"$file_path\" - < \"$input_file\" > \"$checked_file\"; uv run --no-project ruff format --stdin-filename \"$file_path\" - < \"$checked_file\"",
            "python-format",
            "{buffer_path}"
          ]
        }
      }
    }
  },
  "context_servers": {}
}
