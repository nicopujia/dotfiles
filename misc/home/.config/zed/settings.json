// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "autosave": "on_focus_change",
  "soft_wrap": "bounded",
  "preferred_line_length": 120,

  // Remote
  "ssh_connections": [
    {
      "host": "pujia",
      "username": "nico",
      "args": [],
      "projects": [
        {
          "paths": ["/home/nico/jri"],
        },
      ],
    },
  ],

  // Theme
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Monokai Night",
  },

  // Git
  "git": {
    "gutter_debounce": 0,
    "git_gutter": "tracked_files",
  },
  "git_panel": {
    "tree_view": true,
  },

  // Vim
  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "enabled",

  // Auto-completions
  "completions": {
    "words_min_length": 0,
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
  },
  "show_edit_predictions": false,

  // Languages
  "languages": {
    "XML": {
      "formatter": "language_server",
      "tab_size": 2,
    },
    "HTML": {
      "tab_size": 2,
    },
    "CSS": {
      "tab_size": 2,
    },
    "JavaScript": {
      "tab_size": 2,
    },
    "TypeScript": {
      "tab_size": 2,
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-lc",
            "uv run --no-project ruff check --exit-zero --fix --stdin-filename \"$0\" - | uv run --no-project ruff format --stdin-filename \"$0\" -",
            "{buffer_path}",
          ],
        },
      },
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "typeCheckingMode": "recommended",
        },
      },
    },
  },
  "file_types": {
    "svg": ["html"],
  },

  // AI
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "xhigh",
    },
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "flexible": false,
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access",
      },
      "type": "registry",
    },
    "opencode": {
      "type": "extension",
    },
  },
  "language_models": {
    "opencode": {
      "show_go_models": false,
      "show_zen_models": false,
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-2933f100-56df-4b40-b814-913bfc08ee25",
      },
    },
  },

  // Keep for auto-completion on this settings file
  "$schema": "zed://schemas/settings",
}
