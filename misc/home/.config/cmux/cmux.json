{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "shortcuts": {
    "bindings": {
      "openSettings": ["ctrl+b", "shift+,"],
      "reloadConfiguration": ["ctrl+b", "r"],
      "showHideAllWindows": ["ctrl+b", "shift+w"],
      "newWindow": ["ctrl+b", "shift+n"],
      "closeWindow": ["ctrl+b", "shift+x"],
      "toggleFullScreen": ["ctrl+b", "f"],
      "quit": ["ctrl+b", "q"],
      "commandPalette": ["ctrl+b", ":"],
      "sendFeedback": ["ctrl+b", "?"],
      "reopenPreviousSession": ["ctrl+b", "shift+o"],

      "toggleSidebar": ["ctrl+b", "b"],
      "newTab": ["ctrl+b", "s"],
      "openFolder": ["ctrl+b", "o"],
      "goToWorkspace": ["ctrl+b", "w"],
      "nextSidebarTab": ["ctrl+b", ")"],
      "prevSidebarTab": ["ctrl+b", "("],
      "selectWorkspaceByNumber": ["ctrl+b", "shift+1"],
      "renameWorkspace": ["ctrl+b", "$"],
      "editWorkspaceDescription": ["ctrl+b", "shift+e"],
      "focusRightSidebar": ["ctrl+b", "e"],
      "switchRightSidebarToFiles": ["ctrl+b", "shift+f"],
      "switchRightSidebarToFind": ["ctrl+b", "shift+2"],
      "switchRightSidebarToSessions": ["ctrl+b", "shift+3"],
      "switchRightSidebarToFeed": ["ctrl+b", "shift+4"],
      "switchRightSidebarToDock": ["ctrl+b", "shift+5"],
      "closeWorkspace": ["ctrl+b", "&"],

      "newSurface": ["ctrl+b", "c"],
      "nextSurface": ["ctrl+b", "n"],
      "prevSurface": ["ctrl+b", "p"],
      "selectSurfaceByNumber": ["ctrl+b", "1"],
      "renameTab": ["ctrl+b", ","],
      "closeTab": ["ctrl+b", "x"],
      "closeOtherTabsInPane": ["ctrl+b", "shift+t"],
      "reopenClosedBrowserPanel": ["ctrl+b", "u"],
      "toggleTerminalCopyMode": ["ctrl+b", "["],
      "saveFilePreview": ["ctrl+b", "ctrl+s"],

      "focusLeft": ["ctrl+b", "h"],
      "focusRight": ["ctrl+b", "l"],
      "focusUp": ["ctrl+b", "k"],
      "focusDown": ["ctrl+b", "j"],
      "splitRight": ["ctrl+b", "%"],
      "splitDown": ["ctrl+b", "\\\""],
      "toggleSplitZoom": ["ctrl+b", "z"],
      "splitBrowserRight": ["ctrl+b", "shift+%"],
      "splitBrowserDown": ["ctrl+b", "shift+\\\""],

      "openBrowser": ["ctrl+b", "ctrl+o"],
      "focusBrowserAddressBar": ["ctrl+b", "shift+l"],
      "browserBack": ["ctrl+b", "shift+["],
      "browserForward": ["ctrl+b", "]"],
      "browserReload": ["ctrl+b", "shift+r"],
      "browserZoomIn": ["ctrl+b", "+"],
      "browserZoomOut": ["ctrl+b", "-"],
      "browserZoomReset": ["ctrl+b", "0"],
      "toggleBrowserDeveloperTools": ["ctrl+b", "d"],
      "showBrowserJavaScriptConsole": ["ctrl+b", "shift+c"],
      "toggleReactGrab": ["ctrl+b", "ctrl+g"],

      "find": ["ctrl+b", "/"],
      "findInDirectory": ["ctrl+b", "shift+/"],
      "findNext": ["ctrl+b", "g"],
      "findPrevious": ["ctrl+b", "shift+g"],
      "hideFind": ["ctrl+b", "escape"],
      "useSelectionForFind": ["ctrl+b", "ctrl+e"],

      "showNotifications": ["ctrl+b", "i"],
      "jumpToUnread": ["ctrl+b", "shift+u"],
      "triggerFlash": ["ctrl+b", "shift+h"]
    }
  }
}
